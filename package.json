{
    "$schema": "https://schemastore.org/package.json",
    "name": "floodfill",
    "version": "0.0.1",
    "description": "Self-hosted GPX viewer for those with a goal to walk/run/ride every street in a $city",
    "scripts": {
        "build:fe": "tsgo && vite build",
        "watch:fe": "find src | entr npm run build:fe",
        "start:be": "bun src/server.ts",
        "start": "npm run build:fe && npm run start:be"
    },
    "type": "module",
    "license": "MIT",
    "packageManager": "pnpm@10.32.0",
    "devDependencies": {
        "@types/geojson": "7946.0.16",
        "@types/node": "25.5.0",
        "@types/sax": "1.2.7",
        "@typescript/native-preview": "7.0.0-dev.20260330.1",
        "bun": "1.3.11",
        "typescript": "6.0.2",
        "vite": "8.0.3",
        "vite-plugin-solid": "2.11.11"
    },
    "dependencies": {
        "date-fns": "4.1.0",
        "geojson": "0.5.0",
        "maplibre-gl": "5.24.0",
        "sax": "1.6.0",
        "solid-js": "1.9.12",
        "sqlite": "5.1.1",
        "sqlite3": "6.0.1"
    }
}
